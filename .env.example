# App
APP_NAME=PrivRAG
LOG_LEVEL=INFO
LLM_PROVIDER=anthropic          # anthropic | openai

# Database
DATABASE_URL=postgresql+asyncpg://privrag:privrag@localhost:5432/privrag

# ChromaDB
CHROMA_PATH=.chroma
CHROMA_COLLECTION=documents

# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Telegram (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CRM Webhook
CRM_WEBHOOK_URL=http://localhost:8000/webhook/crm

# RAG tuning
COSINE_SIMILARITY_THRESHOLD=0.75
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_CONTEXT_TOKENS=1500
CACHE_TTL_SECONDS=3600

# Privacy
SPACY_ENABLED=false
PII_TOKEN_TTL_SECONDS=7200
# User-uploaded docs are isolated per session and auto-deleted after this window
UPLOAD_TTL_SECONDS=3600

# Auth — leave empty to disable; set a value to require X-API-Key on all endpoints
API_KEY=
MAX_UPLOAD_SIZE_MB=10

# CORS — comma-separated allowed frontend origins, or "*" for any (e.g. https://privrag.vercel.app)
CORS_ORIGINS=*

# Audit — HMAC secret for query_hash in audit logs (prevents dictionary attacks on low-entropy queries)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUDIT_HASH_SECRET=

# Auth (Fase 1 — cuentas). Set JWT_SECRET in production so tokens survive restarts.
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080
PASSWORD_MIN_LENGTH=8
